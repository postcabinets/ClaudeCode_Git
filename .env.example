# Notion: Integration の Secret（ntn_ で始まる値）。リポジトリにコミットしないこと。
NOTION_TOKEN=

# Notion で作成した「ハブ用ページ」をインテグレーションに共有し、そのページ ID（32文字のハイフン付き）
NOTION_PARENT_PAGE_ID=

# Discord（Bot を再発行したらここを更新。チャットやログに貼らない）
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# 通知用（任意）: サーバーで Webhook を作成し URL を設定すると、スクリプトから投稿しやすい
DISCORD_WEBHOOK_URL=
